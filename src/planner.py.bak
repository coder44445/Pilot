"""
Generates a structured study plan from PDF text + user profile using an LLM.

v2 fixes:
- Small-model-safe extraction: sends text in chunks, simpler prompt, line-by-line format
- Robust JSON repair (fixes truncation, trailing commas, unquoted keys, <think> tags)
- Interactive topic review: user sees all extracted topics and can remove/reorder/mark hard/easy
- Planning prompt sends minimal topic payload (no subtopics) to avoid token overflow
"""

import json
import re
from src.llm import LLMClient
from src.display import console


# ── Prompts ────────────────────────────────────────────────────────────────── #

EXTRACTION_SYSTEM = """You extract topic lists from educational text.
Output ONLY valid JSON. No thinking, no explanation, no markdown fences."""

# Intentionally minimal — small models choke on big schemas
EXTRACTION_PROMPT = """List the main topics/chapters in this educational content.

Title: {title}
Text excerpt:
---
{text}
---

Output JSON in this exact format (5 to 15 topics):
{{
  "subject": "short subject name",
  "description": "one sentence about what this covers",
  "topics": [
    {{"id": "t1", "title": "Topic Title", "difficulty": "beginner", "estimated_hours": 1.5, "description": "what this covers", "subtopics": ["sub1", "sub2"]}},
    {{"id": "t2", "title": "Topic Title", "difficulty": "intermediate", "estimated_hours": 2.0, "description": "what this covers", "subtopics": ["sub1"]}}
  ]
}}

Difficulty must be one of: beginner, intermediate, advanced.
Output ONLY the JSON object."""


PLANNING_SYSTEM = """You are a study planner. Output ONLY valid JSON. No explanation."""

PLANNING_PROMPT = """Create a {total_days}-day study schedule.

Topics (use these exact ids):
{topics_simple}

Rules:
- Day 1 = orientation overview
- Day {total_days} = review + consolidation  
- Every 5-7 days = a review day
- Hard topics get more time. Easy topics go faster.
- {hours_per_day}h per day total
- Skill level: {skill_level}, Goal: {goal}

Hard topics: {hard_topics}
Easy topics: {easy_topics}

Output JSON:
{{
  "days": [
    {{
      "day": 1,
      "title": "Day title",
      "type": "orientation",
      "total_hours": {hours_per_day},
      "day_goal": "By end of today you will...",
      "notes": "",
      "topics": [
        {{"topic_id": "t1", "topic_title": "Title", "focus": "what to focus on", "time_allocation": 1.5, "depth": "overview", "activities": ["activity 1", "activity 2"]}}
      ]
    }}
  ]
}}"""


NOTES_SYSTEM = """You are an educator writing study notes in Markdown. Be clear and practical."""

NOTES_PROMPT = """Write study notes for: {topic_title}

Description: {topic_description}
Subtopics: {subtopics}
Student level: {skill_level} | Goal: {goal} | Style: {learning_style} | Depth: {depth}
{hard_easy_instruction}

Use this structure:
## {topic_title}
### 🎯 What You'll Learn
### 📖 Core Concepts
### 🔑 Key Points
{tldr_section}
### 💡 Examples
### ⚠️ Common Mistakes
{quiz_section}
### 🔗 Related Topics (use [[wiki-link]] format)
---
*Estimated study time: {time_allocation}h*"""


# ── JSON repair ────────────────────────────────────────────────────────────── #

def _repair_json(raw: str) -> dict:
    """
    Multi-stage JSON recovery. Handles the most common small-model failures:
    - <think>...</think> tags (reasoning models like qwen3)
    - ```json ... ``` fences
    - Truncated JSON (missing closing brackets)
    - Trailing commas
    - Single-quoted strings
    """
    text = raw.strip()

    # 1. Strip <think>...</think> blocks (qwen3, deepseek-r1 etc.)
    text = re.sub(r'<think>.*?</think>', '', text, flags=re.DOTALL).strip()

    # 2. Strip markdown fences
    text = re.sub(r'^```(?:json)?\s*', '', text)
    text = re.sub(r'\s*```$', '', text)
    text = text.strip()

    # 3. Try direct parse first
    try:
        return json.loads(text)
    except json.JSONDecodeError:
        pass

    # 4. Extract first {...} block
    match = re.search(r'\{', text)
    if match:
        text = text[match.start():]

    # 5. Fix trailing commas before } or ]
    text = re.sub(r',\s*([}\]])', r'\1', text)

    # 6. Try again
    try:
        return json.loads(text)
    except json.JSONDecodeError:
        pass

    # 7. Truncation repair — count open braces/brackets and close them
    text = _close_truncated_json(text)
    try:
        return json.loads(text)
    except json.JSONDecodeError as e:
        raise ValueError(
            f"Could not parse LLM response as JSON.\n"
            f"Error: {e}\n"
            f"Response (first 600 chars):\n{raw[:600]}"
        )


def _close_truncated_json(text: str) -> str:
    """Add missing closing brackets/braces to truncated JSON."""
    stack = []
    in_string = False
    escape_next = False

    for ch in text:
        if escape_next:
            escape_next = False
            continue
        if ch == '\\' and in_string:
            escape_next = True
            continue
        if ch == '"':
            in_string = not in_string
            continue
        if in_string:
            continue
        if ch in ('{', '['):
            stack.append('}' if ch == '{' else ']')
        elif ch in ('}', ']'):
            if stack and stack[-1] == ch:
                stack.pop()

    # Remove trailing comma before we close
    text = text.rstrip().rstrip(',')
    # Close in reverse order
    return text + ''.join(reversed(stack))


# ── Interactive topic review ───────────────────────────────────────────────── #

def review_topics(topics: list, user_profile: dict) -> list:
    """
    Show extracted topics to the user and let them:
    - Remove topics they don't want
    - Mark topics as hard or easy (updates user_profile in place)
    - Accept all as-is
    """
    console.print("\n" + "─" * 60)
    console.print("[bold cyan]📋 Review Extracted Topics[/bold cyan]")
    console.print("─" * 60)
    console.print(f"\n[bold]Found {len(topics)} topics:[/bold]\n")

    for i, t in enumerate(topics, 1):
        diff_color = {"beginner": "green", "intermediate": "yellow", "advanced": "red"}.get(
            t.get("difficulty", "intermediate"), "white"
        )
        console.print(
            f"  [bold]{i:2d}.[/bold] [{diff_color}]{t['title']}[/{diff_color}]"
            f"  [dim]~{t.get('estimated_hours', 1.5)}h · {t.get('difficulty', '?')}[/dim]"
        )
        if t.get("description"):
            console.print(f"      [dim]{t['description'][:80]}[/dim]")

    console.print("\n[dim]Legend: [green]beginner[/green] [yellow]intermediate[/yellow] [red]advanced[/red][/dim]")

    console.print("\nWhat do you want to do?")
    console.print("  [bold]a[/bold] = Accept all topics as-is")
    console.print("  [bold]r[/bold] = Remove topics I don't need")
    console.print("  [bold]h[/bold] = Mark hard/easy topics now (updates your profile)")

    choice = input("\nEnter a/r/h [a]: ").strip().lower() or "a"

    if choice == "r":
        topics = _remove_topics(topics)

    if choice == "h" or (choice == "a" and not user_profile.get("hard_topics") and not user_profile.get("easy_topics")):
        _mark_hard_easy(topics, user_profile)

    console.print(f"\n[green]✓ Proceeding with {len(topics)} topics[/green]")
    return topics


def _remove_topics(topics: list) -> list:
    console.print(
        "\nEnter topic numbers to [bold red]REMOVE[/bold red] (comma-separated), or press Enter to keep all:"
    )
    raw = input("Remove: ").strip()
    if not raw:
        return topics

    to_remove = set()
    for part in raw.split(","):
        part = part.strip()
        if part.isdigit():
            idx = int(part) - 1
            if 0 <= idx < len(topics):
                to_remove.add(idx)

    kept = [t for i, t in enumerate(topics) if i not in to_remove]
    removed_names = [topics[i]["title"] for i in sorted(to_remove)]
    if removed_names:
        console.print(f"  [dim]Removed: {', '.join(removed_names)}[/dim]")
    return kept


def _mark_hard_easy(topics: list, user_profile: dict) -> None:
    console.print(
        "\nEnter topic numbers that are [bold red]HARD[/bold red] for you (comma-separated, or Enter to skip):"
    )
    hard_raw = input("Hard: ").strip()
    hard_titles = []
    for part in hard_raw.split(","):
        part = part.strip()
        if part.isdigit():
            idx = int(part) - 1
            if 0 <= idx < len(topics):
                hard_titles.append(topics[idx]["title"])

    console.print(
        "\nEnter topic numbers that are [bold green]EASY[/bold green] for you (comma-separated, or Enter to skip):"
    )
    easy_raw = input("Easy: ").strip()
    easy_titles = []
    for part in easy_raw.split(","):
        part = part.strip()
        if part.isdigit():
            idx = int(part) - 1
            if 0 <= idx < len(topics):
                easy_titles.append(topics[idx]["title"])

    if hard_titles:
        user_profile["hard_topics"] = list(set(user_profile.get("hard_topics", []) + hard_titles))
        console.print(f"  [red]Hard:[/red] {', '.join(hard_titles)}")
    if easy_titles:
        user_profile["easy_topics"] = list(set(user_profile.get("easy_topics", []) + easy_titles))
        console.print(f"  [green]Easy:[/green] {', '.join(easy_titles)}")


# ── Main pipeline ──────────────────────────────────────────────────────────── #

def generate_study_plan(llm: LLMClient, pdf_text: str, user_profile: dict, pdf_metadata: dict) -> dict:
    """
    Full pipeline:
      1. Extract topics (chunked, small-model safe)
      2. Interactive topic review — user selects/marks topics
      3. Build day-by-day schedule
      4. Generate notes per topic
    """

    # ── Step 1: Extract topics ── #
    console.print("  [dim]Step 1/3: Extracting topics from PDF...[/dim]")

    words = pdf_text.split()

    # Use first 8k words only — enough for table of contents / intro chapters
    # Small models (0.6b) fail badly on large contexts
    text_sample = " ".join(words[:8_000])

    extraction_response = llm.chat(
        system_prompt=EXTRACTION_SYSTEM,
        user_prompt=EXTRACTION_PROMPT.format(
            title=pdf_metadata.get("title", "Unknown"),
            text=text_sample,
        ),
        json_mode=True,
    )

    extracted = _repair_json(extraction_response)
    topics = extracted.get("topics", [])

    # Ensure every topic has required fields with safe defaults
    for i, t in enumerate(topics):
        t.setdefault("id", f"t{i+1}")
        t.setdefault("title", f"Topic {i+1}")
        t.setdefault("description", "")
        t.setdefault("subtopics", [])
        t.setdefault("estimated_hours", 1.5)
        t.setdefault("difficulty", "intermediate")
        t.setdefault("prerequisites", [])

    console.print(f"  [green]✓[/green] Found {len(topics)} topics")

    # ── Step 2: Interactive topic review ── #
    topics = review_topics(topics, user_profile)

    # ── Step 3: Build schedule ── #
    console.print("\n[bold yellow]🧠 Building personalized schedule...[/bold yellow]")

    # Send a minimal topic summary to avoid token overflow on small models
    topics_simple = "\n".join(
        f'- id: "{t["id"]}", title: "{t["title"]}", difficulty: {t.get("difficulty","intermediate")}, hours: {t.get("estimated_hours",1.5)}'
        for t in topics
    )

    planning_response = llm.chat(
        system_prompt=PLANNING_SYSTEM,
        user_prompt=PLANNING_PROMPT.format(
            total_days=user_profile["total_days"],
            hours_per_day=user_profile["hours_per_day"],
            skill_level=user_profile["skill_level"],
            goal=user_profile["goal"],
            learning_style=user_profile.get("learning_style", "mixed"),
            hard_topics=", ".join(user_profile.get("hard_topics", [])) or "none",
            easy_topics=", ".join(user_profile.get("easy_topics", [])) or "none",
            topics_simple=topics_simple,
        ),
        json_mode=True,
    )

    schedule = _repair_json(planning_response)
    days = schedule.get("days", [])
    console.print(f"  [green]✓[/green] Scheduled {len(days)} days")

    # ── Step 4: Write notes per topic ── #
    console.print("\n[bold yellow]📝 Writing study notes...[/bold yellow]")

    topic_map = {t["id"]: t for t in topics}

    scheduled_topic_ids = set()
    for day in days:
        for t in day.get("topics", []):
            tid = t.get("topic_id")
            if tid:
                scheduled_topic_ids.add(tid)

    # Fallback: if schedule references unknown ids, include all topics
    if not scheduled_topic_ids:
        scheduled_topic_ids = {t["id"] for t in topics}

    notes_map = {}
    total = len(scheduled_topic_ids)

    for i, topic_id in enumerate(scheduled_topic_ids, 1):
        topic_data = topic_map.get(topic_id)
        if not topic_data:
            continue

        console.print(f"  [dim]  {i}/{total}: {topic_data['title']}[/dim]")

        depth = "standard"
        time_alloc = topic_data.get("estimated_hours", 1.5)
        for day in days:
            for t in day.get("topics", []):
                if t.get("topic_id") == topic_id:
                    depth = t.get("depth", "standard")
                    time_alloc = t.get("time_allocation", time_alloc)
                    break

        hard_easy = ""
        title_lower = topic_data["title"].lower()
        if any(h.lower() in title_lower for h in user_profile.get("hard_topics", [])):
            hard_easy = "⚠️ HARD topic — go extra deep, more examples, explain carefully."
        elif any(e.lower() in title_lower for e in user_profile.get("easy_topics", [])):
            hard_easy = "✅ EASY topic — be concise, include practice exercises."

        tldr = "### 📌 TL;DR\n(one sentence summary)\n" if user_profile.get("include_summaries") else ""
        quiz = (
            "### 🧪 Quiz Yourself\n1. ?\n2. ?\n3. ?\n"
            if user_profile.get("include_quizzes")
            else ""
        )

        notes_response = llm.chat(
            system_prompt=NOTES_SYSTEM,
            user_prompt=NOTES_PROMPT.format(
                topic_title=topic_data["title"],
                topic_description=topic_data.get("description", ""),
                subtopics=", ".join(topic_data.get("subtopics", [])),
                skill_level=user_profile["skill_level"],
                goal=user_profile["goal"],
                learning_style=user_profile.get("learning_style", "mixed"),
                depth=depth,
                hard_easy_instruction=hard_easy,
                tldr_section=tldr,
                quiz_section=quiz,
                time_allocation=time_alloc,
            ),
        )
        notes_map[topic_id] = notes_response

    console.print(f"  [green]✓[/green] Notes written for {len(notes_map)} topics")

    return {
        "subject": extracted.get("subject", pdf_metadata.get("title", "Study Plan")),
        "description": extracted.get("description", ""),
        "topics": topics,
        "topic_map": topic_map,
        "days": days,
        "notes_map": notes_map,
        "user_profile": user_profile,
        "pdf_metadata": pdf_metadata,
    }
